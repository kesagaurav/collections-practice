	public static String PrefixString(String str[]) {
		Arrays.sort(str);
		char[] a=str[0].toCharArray();
		char[] b=str[str.length-1].toCharArray();
		StringBuilder sb=new StringBuilder();
		for(int i=0;i<a.length;i++) {
			if(a[i]!=b[i]) 
				break;
				sb.append(a[i]);
			
		}
		return sb.toString();
	}
		
