import java.util.Arrays;

public class Main {

	public static void main(String[] args) {

		String str[]= {"flower","flow","flight"};
		PrefixString(str);
	}
	
	public static void PrefixString(String str[]) {
	long count=	Arrays.stream(str).filter(a->a.contains("fl")).count();
	System.out.println(count);
		
	}

}
